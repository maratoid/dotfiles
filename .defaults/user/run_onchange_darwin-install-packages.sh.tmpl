{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF

{{ range .packages.manual -}}
{{ . }}
{{ end -}}

{{ range .packages.mise -}}
mise use -g {{ . }}
{{ end -}}
{{ end -}}